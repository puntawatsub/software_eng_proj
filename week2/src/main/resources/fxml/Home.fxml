<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="365.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.puntawat.metsofteng2.week2.controller.HomeController">
   <children>
      <VBox layoutX="123.0" layoutY="116.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <MenuBar>
              <menus>
                <Menu fx:id="menus" mnemonicParsing="false" text="%language">
                     <items>
                        <RadioMenuItem id="en_US" fx:id="englishToggle" mnemonicParsing="false" onAction="#onLanguageSelected" text="English">
                           <toggleGroup>
                              <ToggleGroup fx:id="languageToggleGroup" />
                           </toggleGroup>
                        </RadioMenuItem>
                        <RadioMenuItem id="fi_FI" fx:id="finnishToggle" mnemonicParsing="false" onAction="#onLanguageSelected" text="suomi" toggleGroup="$languageToggleGroup" />
                        <RadioMenuItem id="sv_SE" fx:id="swedishToggle" mnemonicParsing="false" onAction="#onLanguageSelected" text="svenska" toggleGroup="$languageToggleGroup" />
                        <RadioMenuItem id="ja_JP" fx:id="japaneseToggle" mnemonicParsing="false" onAction="#onLanguageSelected" text="日本語" toggleGroup="$languageToggleGroup" />
                        <RadioMenuItem id="ar_AE" fx:id="arabicToggle" mnemonicParsing="false" onAction="#onLanguageSelected" text="العربية" toggleGroup="$languageToggleGroup" />
                     </items>
                </Menu>
              </menus>
            </MenuBar>
            <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="itemColumn" editable="false" prefWidth="238.0" sortable="false" text="%Item" />
                <TableColumn fx:id="quantityColumn" editable="false" prefWidth="61.0" sortable="false" text="%Quantity" />
                  <TableColumn fx:id="priceColumn" editable="false" prefWidth="63.0" sortable="false" text="%Price" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="50.0">
               <children>
                  <HBox alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                     <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="%total_cost" />
                        <Text fx:id="costLabel" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-background-color: white;" text="Cost" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button fx:id="addItemButton" mnemonicParsing="false" text="%add_item" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
